# Backend
BACKEND_HOST_ADDRESS=127.0.0.1
BACKEND_HOST_PORT=8000
BACKEND_CONTAINER_PORT=8000
BACKEND_CONTAINER_ADDRESS=0.0.0.0
BACKEND_NAME=lms-backend
BACKEND_DEBUG=false
BACKEND_RELOAD=false
BACKEND_ENABLE_INTERACTIONS=true
BACKEND_ENABLE_LEARNERS=true
BACKEND_CORS_ORIGINS=[]

# Postgres
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=changeme
POSTGRES_HOST_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=5432
CONST_POSTGRESQL_SERVICE_NAME=postgres
CONST_POSTGRESQL_DEFAULT_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme
PGADMIN_HOST_ADDRESS=127.0.0.1
PGADMIN_HOST_PORT=5050
CONST_PGADMIN_CONTAINER_PORT=80

# LMS
LMS_API_KEY=changeme

# Autochecker
AUTOCHECKER_API_URL=http://autochecker
AUTOCHECKER_API_LOGIN=login
AUTOCHECKER_API_PASSWORD=password

# Nanobot
LLM_API_KEY=my-secret-qwen-key
LLM_API_MODEL=qwen-coder
NANOBOT_GATEWAY_CONTAINER_ADDRESS=0.0.0.0
NANOBOT_GATEWAY_CONTAINER_PORT=8001
NANOBOT_WEBCHAT_CONTAINER_ADDRESS=0.0.0.0
NANOBOT_WEBCHAT_CONTAINER_PORT=8002
NANOBOT_ACCESS_KEY=changeme

# Qwen Code API
QWEN_CODE_API_HOST_ADDRESS=127.0.0.1
QWEN_CODE_API_HOST_PORT=8080
QWEN_CODE_API_CONTAINER_PORT=8080
QWEN_CODE_API_CONTAINER_ADDRESS=0.0.0.0
QWEN_CODE_API_MODEL=qwen2.5-coder
QWEN_CODE_API_LOG_LEVEL=info
QWEN_CODE_API_MAX_RETRIES=3
QWEN_CODE_API_RETRY_DELAY_MS=1000
QWEN_CODE_API_AUTH_USE=false
QWEN_CODE_API_LOG_REQUESTS=false
QWEN_CODE_API_KEY=

# Caddy / Gateway
CADDY_CONTAINER_PORT=80
GATEWAY_HOST_ADDRESS=0.0.0.0
GATEWAY_HOST_PORT=80

# VictoriaLogs
VICTORIALOGS_HOST_ADDRESS=127.0.0.1
VICTORIALOGS_HOST_PORT=9428
CONST_VICTORIALOGS_CONTAINER_PORT=9428

# VictoriaTraces
VICTORIATRACES_HOST_ADDRESS=127.0.0.1
